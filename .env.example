# Mode: "dev" (local .env + files) or "prod" (HashiCorp Vault)
MODE=prod

# --- Dev mode settings ---
DISCORD_TOKEN=your-discord-token-here     # Required in dev mode
GOOGLE_CREDENTIALS_FILE=data/credentials.json  # Path to Google OAuth client credentials
GOOGLE_TOKEN_DIR=data/tokens              # Where to store per-user OAuth tokens

# --- Prod mode settings (HashiCorp Vault) ---
VAULT_ADDR=http://your-vps-ip:8200       # Vault server address
VAULT_ROLE_ID=your-role-id-here          # AppRole role ID
VAULT_SECRET_ID=your-secret-id-here      # AppRole secret ID

# Bot Settings
POLL_INTERVAL_SECONDS=60                  # How often to check for new calendar events
TIMEZONE=UTC                              # Default timezone for display

# Monitoring
METRICS_PORT=9090                         # Prometheus metrics endpoint port
