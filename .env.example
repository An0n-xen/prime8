# Mode: "dev" (local .env + files) or "prod" (HashiCorp Vault)
MODE=prod

# --- Dev mode settings ---
DISCORD_TOKEN=your-discord-token-here     # Required in dev mode
GOOGLE_CREDENTIALS_FILE=data/credentials.json  # Path to Google OAuth client credentials
GOOGLE_TOKEN_DIR=data/tokens              # Where to store per-user OAuth tokens

# --- Prod mode settings (HashiCorp Vault) ---
VAULT_ADDR=http://your-vps-ip:8200       # Vault server address
VAULT_ROLE_ID=your-role-id-here          # AppRole role ID
VAULT_SECRET_ID=your-secret-id-here      # AppRole secret ID

# Bot Settings
POLL_INTERVAL_SECONDS=60                  # How often to check for new calendar events
TIMEZONE=UTC                              # Default timezone for display
OAUTH_CALLBACK_HOST=localhost             # Set to your VPS IP/domain in prod

# Monitoring
METRICS_PORT=9090                         # Prometheus metrics endpoint port

# --- GitHub Analytics ---
GITHUB_TOKEN=ghp_your_personal_access_token  # GitHub PAT with public_repo scope
REDIS_URL=redis://localhost:6379             # Redis connection URL
SUPABASE_URL=https://your-project.supabase.co  # Supabase project URL
SUPABASE_KEY=your-supabase-anon-key          # Supabase anon/service key
HF_API_TOKEN=hf_your_huggingface_token       # Hugging Face API token (optional, for AI features)
SNAPSHOT_INTERVAL_HOURS=4                    # How often to snapshot star counts
BREAKOUT_SCAN_HOURS=6                        # How often to run breakout detection
DEFAULT_BREAKOUT_MULTIPLIER=3.0              # Default breakout threshold multiplier
TRENDING_CACHE_TTL_SECONDS=3600              # Cache TTL for trending results
DIGEST_TIME=08:00                            # Time for daily digest (HH:MM)
